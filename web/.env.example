# Copy to .env.local (never commit).
# Base URL of the ErixOpti .NET local API (no trailing slash).
# When set, all API routes proxy to the same paths on the host.
#
#   POST /api/optimize
#   GET  /api/optimize/plan
#   GET  /api/downloads
#   POST /api/downloads       { "id": "vcredist-x64" }
#   POST /api/tools           { "action": "deep-clean" }
#
ERIXOTI_HOST=http://127.0.0.1:5077
