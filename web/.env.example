# Copy to .env.local (never commit secrets).
# Base URL of the ErixOpti WinUI / .NET local API (no trailing slash).
# When set, Next.js API routes forward to the same paths on the host:
#   POST /api/optimize
#   GET  /api/optimize/plan
#   GET  /api/downloads
#   POST /api/downloads   { "id": "vcredist-x64" }
ERIXOTI_HOST=http://127.0.0.1:5077
