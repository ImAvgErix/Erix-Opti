<Page
    x:Class="ErixOpti.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ErixOpti.Views"
    x:DataType="views:LogPage"
    mc:Ignorable="d">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16"
          animations:Implicit.ShowAnimations="{StaticResource AppEntranceAnimations}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Style="{StaticResource PageTitleStyle}" Text="Diagnostics log" />
        <TextBlock Grid.Row="1" Style="{StaticResource PageSubtitleStyle}"
                   Text="Real-time Serilog output — also written to %LocalAppData%\ErixOpti\logs." />

        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8">
            <Button
                Command="{x:Bind ViewModel.ExportCommand, Mode=OneWay}"
                Style="{StaticResource AccentButtonStyle}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE9F9;" FontSize="14" />
                    <TextBlock Text="Export log to desktop" />
                </StackPanel>
            </Button>
        </StackPanel>

        <Border
            Grid.Row="3"
            Style="{StaticResource GlassCardStyle}">
            <ListView
                ItemsSource="{x:Bind ViewModel.Lines, Mode=OneWay}"
                SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock
                            FontFamily="Cascadia Code, Consolas, monospace"
                            FontSize="12"
                            IsTextSelectionEnabled="True"
                            Opacity="0.85"
                            Text="{x:Bind}"
                            TextWrapping="WrapWholeWords" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
