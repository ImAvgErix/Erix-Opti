<Page
    x:Class="ErixOpti.Views.LogPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ani="using:CommunityToolkit.WinUI.Animations"
    xmlns:views="using:ErixOpti.Views"
    x:DataType="views:LogPage">
    <Grid Padding="{StaticResource PagePadding}" RowSpacing="16" ani:Implicit.ShowAnimations="{StaticResource Entrance}">
        <Grid.RowDefinitions><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="Auto" /><RowDefinition Height="*" /></Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Style="{StaticResource PageTitle}" Text="Log" />
        <TextBlock Grid.Row="1" Style="{StaticResource PageSub}" Text="Diagnostics — also in %LocalAppData%\ErixOpti\logs." />
        <Button Grid.Row="2" Command="{x:Bind VM.ExportCommand}" Padding="16,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}">
            <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE9F9;" FontSize="14" /><TextBlock Text="Export log" /></StackPanel>
        </Button>
        <Border Grid.Row="3" Style="{StaticResource GlassCard}">
            <ListView ItemsSource="{x:Bind VM.Lines, Mode=OneWay}" SelectionMode="None">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="x:String">
                        <TextBlock FontFamily="Cascadia Code, Consolas, monospace" FontSize="12" Opacity="0.85" Text="{x:Bind}" TextWrapping="WrapWholeWords" IsTextSelectionEnabled="True" />
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
