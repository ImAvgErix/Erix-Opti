<Page
    x:Class="ErixOpti.Views.ToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ani="using:CommunityToolkit.WinUI.Animations"
    xmlns:views="using:ErixOpti.Views"
    x:DataType="views:ToolsPage">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16" ani:Implicit.ShowAnimations="{StaticResource Entrance}">
            <TextBlock Style="{StaticResource PageTitle}" Text="Tools" />
            <TextBlock Style="{StaticResource PageSub}" Text="System cleanup, safety, and quick access." />

            <Border Style="{StaticResource GlassCard}" Padding="16,12">
                <TextBlock FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind VM.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" />
            </Border>

            <TextBlock Style="{StaticResource Section}" Text="CLEANUP" />
            <Border Style="{StaticResource GlassCard}">
                <StackPanel Spacing="12">
                    <TextBlock Style="{StaticResource Label}" Text="TEMP, Prefetch, WU cache, event logs, DISM component cleanup." TextWrapping="Wrap" />
                    <ProgressBar Style="{StaticResource AccentProgress}" Value="{x:Bind VM.CleanupProgress, Mode=OneWay}" Visibility="{x:Bind VM.IsCleaning, Mode=OneWay}" />
                    <Button Command="{x:Bind VM.DeepCleanCommand}" IsEnabled="{x:Bind VM.IsNotCleaning, Mode=OneWay}"
                            Padding="24,12" CornerRadius="8" Background="{StaticResource AppAccentCyanBrush}" Foreground="#09090B" FontWeight="Bold">
                        <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE74D;" FontSize="16" /><TextBlock Text="Deep Clean" FontWeight="Bold" /></StackPanel>
                    </Button>
                </StackPanel>
            </Border>

            <TextBlock Style="{StaticResource Section}" Text="SAFETY" />
            <Border Style="{StaticResource GlassCard}">
                <Button Command="{x:Bind VM.CreateRestorePointCommand}" Padding="16,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}">
                    <StackPanel Orientation="Horizontal" Spacing="8"><FontIcon Glyph="&#xE777;" FontSize="14" /><TextBlock Text="Create Restore Point" /></StackPanel>
                </Button>
            </Border>

            <TextBlock Style="{StaticResource Section}" Text="CONTROL PANEL" />
            <Border Style="{StaticResource GlassCard}">
                <StackPanel Spacing="6">
                    <Button Click="OnCpl" Tag="appwiz.cpl" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xE74C;" FontSize="14" /><TextBlock Text="Programs and Features" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="powercfg.cpl" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xEBB1;" FontSize="14" /><TextBlock Text="Power Options" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="devmgmt.msc" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xE964;" FontSize="14" /><TextBlock Text="Device Manager" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="services.msc" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xE912;" FontSize="14" /><TextBlock Text="Services" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="diskmgmt.msc" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xEDA2;" FontSize="14" /><TextBlock Text="Disk Management" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="eventvwr.msc" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xE9D9;" FontSize="14" /><TextBlock Text="Event Viewer" /></StackPanel></Button>
                    <Button Click="OnCpl" Tag="firewall.cpl" Padding="12,8" CornerRadius="8" Background="Transparent" BorderBrush="{StaticResource AppGlassBorderBrush}" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"><StackPanel Orientation="Horizontal" Spacing="10"><FontIcon Glyph="&#xE72E;" FontSize="14" /><TextBlock Text="Firewall" /></StackPanel></Button>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
