<Page
    x:Class="ErixOpti.Views.OptimizationsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:ani="using:CommunityToolkit.WinUI.Animations"
    xmlns:views="using:ErixOpti.Views"
    x:DataType="views:OptimizationsPage">
    <ScrollViewer>
        <StackPanel Padding="{StaticResource PagePadding}" Spacing="16" ani:Implicit.ShowAnimations="{StaticResource Entrance}">
            <TextBlock Style="{StaticResource PageTitle}" Text="Optimize" />
            <TextBlock Style="{StaticResource PageSub}" Text="One-click hardware-aware optimization with automatic backup." />

            <Border Style="{StaticResource HeroCard}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <TextBlock Style="{StaticResource Label}" HorizontalAlignment="Center" Text="{x:Bind VM.HardwareSummary, Mode=OneWay}" />
                    <Button Command="{x:Bind VM.AutoOptimizeCommand}" IsEnabled="{x:Bind VM.IsNotRunning, Mode=OneWay}"
                            HorizontalAlignment="Center" Padding="32,14" CornerRadius="8"
                            Background="{StaticResource AppAccentCyanBrush}" Foreground="#09090B" FontWeight="Bold" FontSize="15">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <FontIcon Glyph="&#xE945;" FontSize="18" />
                            <TextBlock Text="Auto Optimize" FontWeight="Bold" FontSize="15" />
                        </StackPanel>
                    </Button>
                    <ProgressBar Style="{StaticResource AccentProgress}" Value="{x:Bind VM.ProgressPercent, Mode=OneWay}" Width="400"
                                 Visibility="{x:Bind VM.IsRunning, Mode=OneWay}" />
                    <TextBlock Style="{StaticResource Label}" HorizontalAlignment="Center" Text="{x:Bind VM.CurrentStep, Mode=OneWay}" />
                </StackPanel>
            </Border>

            <Border Style="{StaticResource GlassCard}" Padding="16,12">
                <TextBlock FontSize="13" Foreground="{StaticResource AppTextSecondaryBrush}" Text="{x:Bind VM.StatusMessage, Mode=OneWay}" TextWrapping="Wrap" />
            </Border>
        </StackPanel>
    </ScrollViewer>
</Page>
