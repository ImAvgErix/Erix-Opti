<Page
    x:Class="ErixOpti.Views.QuickToolsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:CommunityToolkit.WinUI.Controls"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="using:ErixOpti.Views"
    x:DataType="views:QuickToolsPage"
    mc:Ignorable="d">
    <ScrollViewer Padding="{StaticResource PagePadding}">
        <StackPanel
            Spacing="16"
            animations:Implicit.ShowAnimations="{StaticResource AppEntranceAnimations}">

            <TextBlock Style="{StaticResource PageTitleStyle}" Text="Quick Tools" />
            <TextBlock Style="{StaticResource PageSubtitleStyle}"
                       Text="Shortcuts to installers, vendor tools, control panels, and safety utilities." />

            <!-- Status -->
            <Border Padding="12,8" CornerRadius="6"
                    Background="#18FFFFFF"
                    BorderBrush="{StaticResource AppGlassBorderBrush}"
                    BorderThickness="1">
                <TextBlock FontSize="13" Opacity="0.9"
                           Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" />
            </Border>

            <!-- Runtimes -->
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="RUNTIMES" />
            <controls:SettingsCard Description="Latest supported redistributables" Header="VC++ / DirectX">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE896;" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <Button Click="OnOpenUrl"
                            Tag="https://aka.ms/vs/17/release/vc_redist.x64.exe">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="VC++ 2015–2022 Redist (x64)" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl"
                            Tag="https://www.microsoft.com/en-us/download/details.aspx?id=35">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE896;" FontSize="14" />
                            <TextBlock Text="DirectX End-User Runtime" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SettingsCard>

            <!-- External utilities -->
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="EXTERNAL UTILITIES" />
            <controls:SettingsCard Description="Launch if installed locally" Header="GPU &amp; diagnostics tools">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE90F;" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <Button Click="OnOpenUrl"
                            Tag="https://www.techpowerup.com/download/techpowerup-gpu-z/">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            <TextBlock Text="GPU-Z (download)" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl"
                            Tag="https://www.hwinfo.com/download/">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            <TextBlock Text="HWiNFO64 (download)" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl"
                            Tag="https://www.wagnardsoft.com/display-driver-uninstaller-DDU-">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            <TextBlock Text="Display Driver Uninstaller (DDU)" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl"
                            Tag="https://www.techpowerup.com/download/techpowerup-nvcleanstall/">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE8A7;" FontSize="14" />
                            <TextBlock Text="NVCleanInstall (download)" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SettingsCard>

            <!-- Driver pages -->
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="DRIVER DOWNLOADS" />
            <controls:SettingsCard Header="Vendor driver pages" Description="Opens official driver download pages">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE968;" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <Button Click="OnOpenUrl" Tag="https://www.nvidia.com/Download/index.aspx">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                            <TextBlock Text="NVIDIA drivers" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl" Tag="https://www.amd.com/en/support">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                            <TextBlock Text="AMD drivers" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnOpenUrl" Tag="https://www.intel.com/content/www/us/en/download-center/home.html">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE774;" FontSize="14" />
                            <TextBlock Text="Intel drivers" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SettingsCard>

            <!-- Control Panel shortcuts -->
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="CONTROL PANEL" />
            <controls:SettingsCard Header="System panels" Description="Open Windows built-in configuration panels">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE115;" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <Button Click="OnControlPanel" Tag="appwiz.cpl">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE74C;" FontSize="14" />
                            <TextBlock Text="Programs and Features" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnControlPanel" Tag="powercfg.cpl">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xEBB1;" FontSize="14" />
                            <TextBlock Text="Power Options" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnControlPanel" Tag="devmgmt.msc">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE964;" FontSize="14" />
                            <TextBlock Text="Device Manager" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnControlPanel" Tag="ncpa.cpl">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE968;" FontSize="14" />
                            <TextBlock Text="Network Connections" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnControlPanel" Tag="services.msc">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE912;" FontSize="14" />
                            <TextBlock Text="Services" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SettingsCard>

            <!-- Safety -->
            <TextBlock Style="{StaticResource SectionHeaderStyle}" Text="SAFETY" />
            <controls:SettingsCard
                Description="Create backups and export reports"
                Header="Backup &amp; export">
                <controls:SettingsCard.HeaderIcon>
                    <FontIcon Glyph="&#xE72E;" Foreground="{StaticResource RiskLowBrush}" />
                </controls:SettingsCard.HeaderIcon>
                <StackPanel Spacing="8">
                    <Button Click="OnCreateRestorePoint" Style="{StaticResource AccentButtonStyle}">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE777;" FontSize="14" />
                            <TextBlock Text="Create restore point now" />
                        </StackPanel>
                    </Button>
                    <Button Click="OnExportHardwareReport">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <FontIcon Glyph="&#xE9F9;" FontSize="14" />
                            <TextBlock Text="Export full hardware report" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </controls:SettingsCard>

        </StackPanel>
    </ScrollViewer>
</Page>
