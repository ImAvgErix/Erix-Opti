<Window
    x:Class="ErixOpti.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <media:MicaBackdrop Kind="Base" />
    </Window.SystemBackdrop>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <NavigationView
            x:Name="RootNav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="Left"
            IsPaneOpen="True"
            OpenPaneLength="260"
            SelectionChanged="OnNavSelectionChanged">
            <NavigationView.PaneHeader>
                <StackPanel Margin="12,8,0,4" Spacing="2">
                    <TextBlock
                        FontSize="20"
                        FontWeight="Bold"
                        Foreground="{StaticResource AppAccentCyanBrush}"
                        Text="ErixOpti" />
                    <TextBlock
                        FontSize="11"
                        Opacity="0.5"
                        Text="Safe gaming optimization" />
                </StackPanel>
            </NavigationView.PaneHeader>
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Hardware" Tag="hardware">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE964;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Optimizations" Tag="optimizations">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE945;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Quick Tools" Tag="quick">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Log" Tag="log">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
