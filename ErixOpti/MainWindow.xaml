<Window
    x:Class="ErixOpti.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:media="using:Microsoft.UI.Xaml.Media"
    mc:Ignorable="d"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006">
    <Window.SystemBackdrop>
        <media:MicaBackdrop Kind="BaseAlt" />
    </Window.SystemBackdrop>
    <Grid Background="{StaticResource AppBackgroundBrush}">
        <NavigationView
            x:Name="Nav"
            IsBackButtonVisible="Collapsed"
            IsSettingsVisible="False"
            PaneDisplayMode="LeftCompact"
            IsPaneOpen="False"
            OpenPaneLength="200"
            CompactPaneLength="52"
            SelectionChanged="OnNavChanged">
            <NavigationView.PaneHeader>
                <StackPanel Margin="8,12,0,8" Spacing="2">
                    <TextBlock Text="ErixOpti" FontSize="15" FontWeight="Bold"
                               Foreground="{StaticResource AppAccentCyanBrush}" />
                </StackPanel>
            </NavigationView.PaneHeader>
            <NavigationView.Resources>
                <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
            </NavigationView.Resources>
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Hardware" Tag="hw">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE964;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Optimize" Tag="opt">
                    <NavigationViewItem.Icon><FontIcon Glyph="&#xE9D9;" /></NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>
            <Frame x:Name="ContentFrame">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <EntranceThemeTransition FromHorizontalOffset="40" FromVerticalOffset="0" />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Window>
