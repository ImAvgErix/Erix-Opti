<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:animations="using:CommunityToolkit.WinUI.Animations"
    xmlns:conv="using:ErixOpti.Converters">

    <conv:BoolToVisibilityConverter x:Key="BoolToVis" />

    <!-- Dark palette -->
    <Color x:Key="AppBg">#0F0F11</Color>
    <Color x:Key="AppSurface">#18181B</Color>
    <Color x:Key="AppCard">#1E1E22</Color>
    <Color x:Key="AppCardHover">#26262A</Color>
    <Color x:Key="AppAccent">#3B82F6</Color>
    <Color x:Key="AppAccentMuted">#2563EB</Color>
    <Color x:Key="AppBorder">#0AFFFFFF</Color>
    <Color x:Key="AppBorderMed">#14FFFFFF</Color>
    <Color x:Key="TextPrimary">#F0F0F0</Color>
    <Color x:Key="TextSecondary">#71717A</Color>
    <Color x:Key="TextDim">#3F3F46</Color>

    <SolidColorBrush x:Key="AppBackgroundBrush" Color="{StaticResource AppBg}" />
    <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurface}" />
    <SolidColorBrush x:Key="AppCardBrush" Color="{StaticResource AppCard}" />
    <SolidColorBrush x:Key="AppAccentCyanBrush" Color="{StaticResource AppAccent}" />
    <SolidColorBrush x:Key="AppGlassBorderBrush" Color="{StaticResource AppBorder}" />
    <SolidColorBrush x:Key="AppBorderMedBrush" Color="{StaticResource AppBorderMed}" />
    <SolidColorBrush x:Key="AppTextPrimaryBrush" Color="{StaticResource TextPrimary}" />
    <SolidColorBrush x:Key="AppTextSecondaryBrush" Color="{StaticResource TextSecondary}" />
    <SolidColorBrush x:Key="AppTextDimBrush" Color="{StaticResource TextDim}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="#34D399" />
    <SolidColorBrush x:Key="WarningBrush" Color="#FBBF24" />
    <SolidColorBrush x:Key="ErrorBrush" Color="#F87171" />

    <!-- NavigationView overrides -->
    <SolidColorBrush x:Key="NavigationViewContentBackground" Color="Transparent" />
    <SolidColorBrush x:Key="NavigationViewDefaultPaneBackground" Color="{StaticResource AppBg}" />
    <SolidColorBrush x:Key="NavigationViewExpandedPaneBackground" Color="{StaticResource AppBg}" />

    <CornerRadius x:Key="ControlCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="CardRadius">10</CornerRadius>
    <CornerRadius x:Key="CardRadiusLg">14</CornerRadius>
    <CornerRadius x:Key="PillRadius">20</CornerRadius>
    <Thickness x:Key="CardPadding">16,14</Thickness>
    <Thickness x:Key="PagePadding">28,20,28,20</Thickness>

    <Style x:Key="GlassCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppCardBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppGlassBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardRadius}" />
        <Setter Property="Padding" Value="{StaticResource CardPadding}" />
    </Style>
    <Style x:Key="HardwareSnapshotTile" TargetType="Border" BasedOn="{StaticResource GlassCard}">
        <Setter Property="MinHeight" Value="118" />
    </Style>
    <Style x:Key="HeroCard" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource AppSurfaceBrush}" />
        <Setter Property="BorderBrush" Value="{StaticResource AppBorderMedBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="CornerRadius" Value="{StaticResource CardRadiusLg}" />
        <Setter Property="Padding" Value="24,20" />
    </Style>
    <Style x:Key="PageTitle" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
    </Style>
    <Style x:Key="PageSub" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="LineHeight" Value="20" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
    </Style>
    <Style x:Key="Section" TargetType="TextBlock">
        <Setter Property="FontSize" Value="11" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppTextDimBrush}" />
        <Setter Property="CharacterSpacing" Value="100" />
        <Setter Property="Margin" Value="0,20,0,8" />
    </Style>
    <Style x:Key="Label" TargetType="TextBlock">
        <Setter Property="FontSize" Value="13" />
        <Setter Property="Foreground" Value="{StaticResource AppTextSecondaryBrush}" />
    </Style>
    <Style x:Key="Value" TargetType="TextBlock">
        <Setter Property="FontSize" Value="15" />
        <Setter Property="FontWeight" Value="SemiBold" />
        <Setter Property="Foreground" Value="{StaticResource AppTextPrimaryBrush}" />
    </Style>
    <Style x:Key="BigValue" TargetType="TextBlock">
        <Setter Property="FontSize" Value="24" />
        <Setter Property="FontWeight" Value="Bold" />
        <Setter Property="Foreground" Value="{StaticResource AppAccentCyanBrush}" />
        <Setter Property="FontFamily" Value="Segoe UI Variable Display" />
    </Style>
    <Style x:Key="AccentProgress" TargetType="ProgressBar">
        <Setter Property="Foreground" Value="{StaticResource AppAccentCyanBrush}" />
        <Setter Property="Background" Value="#0AFFFFFF" />
        <Setter Property="CornerRadius" Value="3" />
        <Setter Property="Height" Value="4" />
    </Style>

    <animations:ImplicitAnimationSet x:Key="Entrance">
        <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.3" />
        <animations:TranslationAnimation From="0,12,0" To="0" Duration="0:0:0.3" />
    </animations:ImplicitAnimationSet>
    <animations:ImplicitAnimationSet x:Key="FadeIn">
        <animations:OpacityAnimation From="0" To="1" Duration="0:0:0.2" />
    </animations:ImplicitAnimationSet>
</ResourceDictionary>
